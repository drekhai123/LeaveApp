# Copy to .env and adjust values.

# Server
PORT=3000
NODE_ENV=development

# MySQL (MikroORM)
DB_HOST=localhost
DB_PORT=3306
DB_USER=leaveapp
DB_PASSWORD=leaveapp
DB_NAME=leaveapp
# Set to true for managed MySQL with SSL (e.g. cloud providers)
# DB_SSL=false

# Auth (JWT)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1d

# Swagger (disabled when NODE_ENV=production unless SWAGGER_ENABLED is not false)
# SWAGGER_ENABLED=true
# SWAGGER_PATH=api/docs
# SWAGGER_DESCRIPTION=Leave request management API for small companies

# Email (Resend): all outgoing email uses MAIL_FROM + RESEND_API_KEY.
MAIL_FROM=onboarding@resend.dev
RESEND_API_KEY=re_your_api_key
